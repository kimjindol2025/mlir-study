    %result = arith.addi %m, %n : i32
    %result = arith.muli %result, 2 : i32  // ← 주목!
    return %result : i32
  }
}
*/
// 답: ❌ 틀림 (%result가 두 번 정의됨)


// 문제 C:
/*
module {
  func.func @practice_c(%a: i32, %b: i32) -> i32 {
    %0 = arith.addi %a, %b : i32
    %1 = arith.addi %0, 5 : i32
    %2 = arith.muli %1, 2 : i32
    return %2 : i32
  }
}
*/
// 답: ✅ 올바름 (이름표: %0, %1, %2 - 모두 다름)


// ============================================
// 정리: SSA 규칙의 핵심
// ============================================

// ✅ 올바른 패턴:
//    %0 = ...
//    %1 = ... (사용 %0도 가능)
//    %2 = ... (사용 %0, %1도 가능)
//    각 이름표는 한 번씩만 정의됨

// ❌ 틀린 패턴:
//    %0 = ...
//    %0 = ... (같은 이름표 재정의!)

// 핵심:
// - 이름표(%0, %1, %2, ...) 사용은 1회만
// - 입력값(인자, 상수)는 여러 번 사용 가능
// - 이것이 SSA (Static Single Assignment)

// ============================================
