// ============================================
// 초등 1.1: 이름표(SSA) 코드 예제
// ============================================

// 파일 설명:
// - 올바른 MLIR 코드 (✅)
// - 틀린 MLIR 코드 (❌)
// - 주석으로 설명

// ============================================
// 예제 1: 기본 더하기 (올바른 코드)
// ============================================

module {
  func.func @example_add(%a: i32, %b: i32) -> i32 {
    // 올바른 사용: %0이라는 이름표로 결과를 담음
    %0 = arith.addi %a, %b : i32
    return %0 : i32
  }
}

// 분석:
// ✅ %0 이름표가 정확히 한 번만 나타남
// ✅ SSA 규칙 준수


// ============================================
// 예제 2: 연쇄 계산 (올바른 코드)
// ============================================

module {
  func.func @example_chain(%a: i32, %b: i32) -> i32 {
    // 첫 번째 연산: %0에 결과 저장
    %0 = arith.addi %a, %b : i32

    // 두 번째 연산: %1에 결과 저장 (새로운 이름표)
    %1 = arith.muli %0, 2 : i32

    // 세 번째 연산: %2에 결과 저장 (새로운 이름표)
    %2 = arith.subi %1, 3 : i32

    return %2 : i32
  }
}

// 분석:
// ✅ 각 연산마다 다른 이름표 (%0, %1, %2) 사용
// ✅ 어떤 이름표도 재사용하지 않음
// ✅ 완벽한 SSA 형식


// ============================================
// 예제 3: 여러 입력값 처리 (올바른 코드)
// ============================================

module {
  func.func @example_multiple_inputs(
    %apple: i32,
    %banana: i32,
    %orange: i32
  ) -> i32 {
    // apple과 banana를 더함
    %0 = arith.addi %apple, %banana : i32

    // 그 결과와 orange를 더함
    %1 = arith.addi %0, %orange : i32

    return %1 : i32
  }
}

// 분석:
// ✅ %0과 %1이 각각 한 번씩만 정의됨
// ✅ 함수 인자(%apple, %banana, %orange)는 여러 번 사용 가능 (이들은 정의가 아니라 사용)
// ✅ 올바른 패턴


// ============================================
// 예제 4: 의미 있는 이름으로 (올바른 코드)
// ============================================

module {
  func.func @example_meaningful_names(
    %x: f32,
    %y: f32
  ) -> f32 {
    // 더하기
    %sum = arith.addf %x, %y : f32

    // 2배하기
    %doubled = arith.mulf %sum, 2.0 : f32

    // 1을 빼기
    %result = arith.subf %doubled, 1.0 : f32

    return %result : f32
  }
}

// 분석:
// ✅ %sum, %doubled, %result - 의미 있는 이름
// ✅ 각 이름표가 정확히 한 번씩만 정의됨
// ✅ 읽기 쉬운 코드


// ============================================
// 예제 5: 상수 사용 (올바른 코드)
// ============================================

module {
  func.func @example_constants(%n: i32) -> i32 {
    // 상수 10을 %0에 저장
    %0 = arith.constant 10 : i32

    // n과 상수를 더함
    %1 = arith.addi %n, %0 : i32

    // 결과에 2를 곱함
    %2 = arith.muli %1, 2 : i32

    return %2 : i32
  }
}

// 분석:
// ✅ %0, %1, %2 모두 다른 이름표
// ✅ 상수도 SSA 값으로 처리됨


// ============================================
// ❌ 틀린 예제 1: 같은 이름표 두 번 사용
// ============================================

// 주석 처리 (실제로는 에러가 남):
/*
module {
  func.func @wrong_example1(%a: i32, %b: i32) -> i32 {
    %0 = arith.addi %a, %b : i32
    %0 = arith.muli %0, 2 : i32  // ❌ %0을 다시 정의!
    return %0 : i32
  }
}
*/

// 왜 틀렸나?
// ❌ %0이 두 번 나타남 (정의가 두 번)
// ❌ 어떤 %0을 반환하는지 불명확
// ❌ SSA 규칙 위반


// ============================================
// ❌ 틀린 예제 2: 같은 이름표로 여러 값
// ============================================

/*
module {
  func.func @wrong_example2(%x: i32, %y: i32, %z: i32) -> i32 {
    %sum = arith.addi %x, %y : i32
    %sum = arith.addi %sum, %z : i32  // ❌ %sum을 다시 정의!
    return %sum : i32
  }
}
*/

// 왜 틀렸나?
// ❌ %sum이 두 번 정의됨
// ❌ 첫 번째 덧셈 결과가 명확하지 않음
// ❌ SSA 규칙 위반


// ============================================
// 올바른 수정: ❌ 틀린 예제 2를 고쳐보기
// ============================================

module {
  func.func @fixed_example2(%x: i32, %y: i32, %z: i32) -> i32 {
    // 수정: 다른 이름표 사용
    %0 = arith.addi %x, %y : i32    // 첫 번째 덧셈
    %1 = arith.addi %0, %z : i32    // 두 번째 덧셈 (새로운 이름)
    return %1 : i32
  }
}

// 수정 사항:
// ✅ %0과 %1을 사용 (다른 이름표)
// ✅ 각 이름표가 정확히 한 번씩만 정의됨
// ✅ SSA 규칙 준수


// ============================================
// 실습: 다음 코드가 올바른가?
// ============================================

